APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database | redis | sync — laporan AI Google Review butuh worker jalan terus:
#   php artisan queue:work   (produksi: pakai Supervisor, lihat deployment/supervisor-laravel-queue.conf.example)
# Fallback tanpa worker (bisa timeout untuk banyak review): GOOGLE_REVIEW_AI_DISPATCH_SYNC=true di .env
# Antrean khusus job klasifikasi Google Review AI (Supervisor: --queue=...,GOOGLE_REVIEW_AI_QUEUE)
# GOOGLE_REVIEW_AI_QUEUE=google-review-ai
QUEUE_CONNECTION=database

# Antrian job otomasi flow inbox (Supervisor: sertakan omnichannel di --queue=...)
OMNI_FLOW_QUEUE=omnichannel

# AI Writing Assistant (inbox) — default ikut GOOGLE_GEMINI_API_KEY + GOOGLE_REVIEW_* / GUEST_COMMENT_* / AI_PROVIDER
# Tidak perlu OMNI_* jika Guest Comment & Google Review sudah pakai Gemini di atas.
# OMNI_AI_WRITING_ENABLED=true
# OMNI_AI_INCLUDE_CONTEXT=true
system_usr_token_meta=EAASgaCPXZA3IBRn9icE6lv0eph79gLQPFCyrFIH4r5oxyOp5shT5UAw6bEc609bcR7sRQVlcLYVECTGAb4RPRDNkDF3Oki1ZAmq1mvHuFvTsJZBSADCH6RGLKGQSdhjLDVW6INrQpz4ff5S4HX5u63qoM9Mll32ZAXsAcaGd8Q7lOIDdeAz7KI6JpUW6DgZDZD
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# Untuk SendGrid, gunakan konfigurasi berikut:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"
# MAIL_FROM_NAME="Justus Group"

# Untuk Gmail (fallback), gunakan:
# MAIL_ALT_HOST=smtp.gmail.com
# MAIL_ALT_PORT=587
# MAIL_ALT_USERNAME=your_gmail@gmail.com
# MAIL_ALT_PASSWORD=your_app_password
# MAIL_ALT_ENCRYPTION=tls

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_sendgrid_api_key_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="Justus Group"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Apify (Google Maps reviews + Instagram scraper memakai token yang sama)
# APIFY_TOKEN=
# APIFY_GOOGLE_REVIEWS_ACTOR=compass/google-maps-reviews-scraper
# APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
# Antrian job sinkron Instagram (Supervisor: sertakan di --queue=...,instagram-scraper)
# INSTAGRAM_SCRAPER_QUEUE=instagram-scraper
# true = scrape jalan di request yang sama (tanpa queue:work; bisa 10+ menit di browser)
# INSTAGRAM_SCRAPER_DISPATCH_SYNC=false
# Batas tunggu satu run Apify Instagram (detik)
# INSTAGRAM_APIFY_MAX_WAIT=900

# Guest Comment OCR — default ikut AI_PROVIDER. Override hanya OCR (dashboard tetap pakai AI_PROVIDER):
# GUEST_COMMENT_AI_PROVIDER=gemini
# Model Gemini khusus OCR (murah: flash). Kosongkan = pakai GEMINI_MODEL dashboard.
# gemini-2.0-flash sering 404 untuk akun baru — pakai gemini-2.5-flash (atau kosongkan = ikut GEMINI_MODEL)
# GUEST_COMMENT_GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_GEMINI_API_KEY=
# GUEST_COMMENT_OCR_ENABLED=true
# GUEST_COMMENT_OCR_TIMEOUT=120
# Kecilkan gambar sebelum API vision; butuh PHP gd atau imagick
# GUEST_COMMENT_OCR_MAX_IMAGE_EDGE=1600
# GUEST_COMMENT_OCR_JPEG_QUALITY=80
# GUEST_COMMENT_OCR_DEBUG_LOG=false

# Scrapper Google Review — klasifikasi sentimen AI: kosong = ikut AI_PROVIDER. Isi gemini agar hemat sementara dashboard tetap Claude.
# GOOGLE_REVIEW_AI_PROVIDER=gemini
# GOOGLE_REVIEW_GEMINI_MODEL=gemini-2.5-flash

# Meta WhatsApp Cloud API (CRM omnichannel)
META_APP_ID=
META_APP_SECRET=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# Facebook Page (Messenger) + Instagram DM
# Satu Page (default): token + id Page utama
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
# Beberapa Page + Instagram Business ID (untuk balas DM): JSON page_id/ig_id => token
# WAJIB satu baris saja (jangan Enter di tengah). Boleh pakai kutip tunggal di luar:
# META_PAGE_TOKENS='{"1587793758107643":"EAAxx","682421618556416":"EAAyy","17841400914429846":"EAAyy"}'
META_PAGE_TOKENS={}
META_INSTAGRAM_ACCOUNT_ID=
# Instagram API with Instagram Login (alur YouTube — graph.instagram.com)
# Dapatkan token: App > Instagram > API setup with Instagram login > Add account > Generate token
# IG professional account id => token (satu baris JSON)
# META_INSTAGRAM_LOGIN_TOKENS='{"17841400914429846":"IGQ..."}'
META_INSTAGRAM_LOGIN_TOKENS={}
# Label badge inbox per akun IG (ig_professional_id => nama tampilan)
# META_INSTAGRAM_LOGIN_ACCOUNT_LABELS='{"17841400914429846":"Justus","17841462873080478":"Tempayan"}'
META_INSTAGRAM_LOGIN_ACCOUNT_LABELS={}
META_INSTAGRAM_LOGIN_ACCESS_TOKEN=
META_INSTAGRAM_LOGIN_DEFAULT_ID=
META_INSTAGRAM_GRAPH_VERSION=v25.0
# Poll DM Instagram Login tiap menit (disarankan ON, tidak bergantung webhook)
META_INSTAGRAM_INBOX_SYNC_ENABLED=true
# Poll DM Facebook Messenger via Page API (disarankan ON, tidak bergantung webhook)
META_MESSENGER_INBOX_SYNC_ENABLED=true
# Interval sync IG saat inbox web terbuka (detik, default 30)
# OMNI_INSTAGRAM_POLL_SYNC_SECONDS=30
# Saat inbox dibuka: hanya DM N menit terakhir (default 45, sync cepat)
# OMNI_INSTAGRAM_INBOX_SYNC_RECENT_MINUTES=45
# OMNI_MESSENGER_POLL_SYNC_SECONDS=30
# OMNI_MESSENGER_INBOX_SYNC_RECENT_MINUTES=45
# OMNI_MESSENGER_SYNC_NOTIFY_WITHIN_MINUTES=30
META_GRAPH_API_VERSION=v25.0
META_WEBHOOK_VERIFY_TOKEN=
# Set true only for debugging webhook delivery (never in production long-term)
META_WEBHOOK_SKIP_SIGNATURE_VERIFY=false

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_TIMEOUT=5

VITE_APP_NAME="${APP_NAME}"
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"


